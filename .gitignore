# Unreal Engine Gitignore
# Based on standard UE gitignore patterns
# Modified: Source and OnlyGame.sln are now tracked, Saved is ignored

# Build and intermediate files
Binaries/
Intermediate/
DerivedDataCache/
.vscode/
.vs/

# Generated files
# OnlyGame.sln is now tracked (removed from ignore)
*.suo
*.user
*.userosscache
*.sln.docstates

# Cache and temporary files
# Saved directory should be ignored (Unreal Engine generated files)
Saved/
*.log
*.pma

# IDE files
.vs/
.vscode/
.idea/
*.opensdf
*.opendb
*.VC.db
*.VC.opendb

# Mac files
.DS_Store

# UE specific
*.profraw
*.profdata
*.uproject.user

# Shader working directory (optional, depends on your workflow)
# Saved/ShaderWorkingDirectory/

# Temp directories
tmp/
temp/
